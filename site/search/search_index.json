{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u0413\u043b\u0430\u0432\u043d\u0430\u044f","text":""},{"location":"#_1","title":"\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u0440\u0430\u0437\u0434\u0435\u043b\u044b \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u0438","text":"<p>\u041a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0432 aio</p> <p>\u0420\u0435\u0433\u043b\u0430\u043c\u0435\u043d\u0442\u044b \u0437\u0430\u0434\u0430\u0447</p>"},{"location":"aio/campaigns/campaign-desc/","title":"\u041a\u0430\u043a \u043f\u043e\u043f\u0430\u0441\u0442\u044c \u0432 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e \u0438 \u0447\u0442\u043e \u0432\u043d\u0443\u0442\u0440\u0438","text":""},{"location":"aio/campaigns/campaign-desc/#aio","title":"\u041a\u0430\u043a \u0443\u0441\u0442\u0440\u043e\u0435\u043d\u044b \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0432 AIO","text":""},{"location":"aio/campaigns/campaign-desc/#aio_1","title":"\u041f\u0435\u0440\u0435\u0445\u043e\u0434 \u0432 \u0441\u0430\u043c AIO","text":"<p>\u0414\u043b\u044f \u043d\u0430\u0447\u0430\u043b\u0430, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043f\u0435\u0440\u0435\u0439\u0442\u0438 \u0432 \u0441\u0430\u043c AIO \u043f\u043e \u0441\u0441\u044b\u043b\u043a\u0435</p> <p></p>"},{"location":"aio/campaigns/campaign-desc/#_1","title":"\u041a\u0430\u043a \u043f\u0435\u0440\u0435\u0439\u0442\u0438 \u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0439","text":"<p>\u041f\u043e\u0441\u043b\u0435 \u043f\u0435\u0440\u0435\u0445\u043e\u0434\u0430 \u043f\u043e \u0441\u0441\u044b\u043b\u043a\u0435, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0436\u0430\u0442\u044c \u043d\u0430 \u043f\u0443\u043d\u043a\u0442 \u043c\u0435\u043d\u044e <code>Tracker</code>, \u0430 \u0437\u0430\u0442\u0435\u043c \u0432 <code>Campaigns</code></p> <p></p> <p></p> <p>\u0422\u0430\u043a \u0432\u044b\u0433\u043b\u044f\u0434\u0438\u0442 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430 \u0441\u043e \u0432\u0441\u0435\u043c\u0438 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044f\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0431\u044b\u043b\u0438 \u0441\u043e\u0437\u0434\u0430\u043d\u044b \u0434\u043b\u044f \u0431\u0430\u0435\u0440\u0430</p> <p></p> <p></p>"},{"location":"aio/campaigns/campaign-desc/#_2","title":"\u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0444\u0438\u043b\u044c\u0442\u0440\u0430\u0446\u0438\u0438 \u0441\u043f\u0438\u0441\u043a\u0430 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0439 \u0438 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432\u044b\u0432\u043e\u0434\u0430 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0438","text":"<p>\u0421\u043f\u0438\u0441\u043e\u043a \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0439 \u043c\u043e\u0436\u043d\u043e \u0444\u0438\u043b\u044c\u0442\u0440\u043e\u0432\u0430\u0442\u044c \u0438\u043b\u0438 \u0434\u0435\u043b\u0430\u0442\u044c \u043f\u043e\u0438\u0441\u043a \u043f\u043e \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u043c \u043a\u043b\u044e\u0447\u0435\u0432\u044b\u043c \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c:</p> <ol> <li>\u0424\u0438\u043b\u044c\u0442\u0440 \u043f\u043e <code>\u0442\u0435\u0433\u0443 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430</code></li> <li>\u041f\u043e\u0438\u0441\u043a \u043f\u043e \u043a\u0430\u043a\u043e\u043c\u0443-\u0442\u043e <code>\u043a\u043b\u044e\u0447\u0435\u0432\u043e\u043c\u0443 \u0441\u043b\u043e\u0432\u0443</code></li> <li>\u0424\u0438\u043b\u044c\u0442\u0440 \u043f\u043e <code>\u0433\u0435\u043e \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438</code></li> </ol> <p>\u0414\u043b\u044f \u0444\u0438\u043b\u044c\u0442\u0440\u0430 \u043f\u043e \u0442\u0435\u0433\u0443 \u043a\u043e\u043c\u0430\u043d\u0434\u044b, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0436\u0430\u0442\u044c \u043d\u0430 \u043a\u043d\u043e\u043f\u043a\u0443 <code>\u0422\u0435\u0433\u0438</code> \u0438 \u0432\u043e \u0432\u0441\u043f\u043b\u044b\u0432\u0430\u044e\u0449\u0435\u043c \u043e\u043a\u043d\u0435 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0442\u0435\u0433 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430 <code>GGL</code> \u0438\u043b\u0438 <code>FB</code></p> <p></p> <p></p> <p>\u0414\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430 \u043f\u043e \u043a\u043b\u044e\u0447\u0435\u0432\u043e\u043c\u0443 \u0441\u043b\u043e\u0432\u0443, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043f\u0443\u043d\u043a\u0442 <code>\u0422\u0435\u043a\u0441\u0442</code> \u0438 \u0432\u0432\u0435\u0441\u0442\u0438 \u043d\u0443\u0436\u043d\u043e\u0435 \u043a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u0441\u043b\u043e\u0432\u043e (\u0434\u043e\u043c\u0435\u043d, \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043e\u0444\u0444\u0435\u0440\u0430, \u043b\u0438\u0431\u043e \u043a\u0430\u043a\u0438\u0435-\u0442\u043e \u0441\u0432\u043e\u0438 \u0434\u043e\u043f. \u043e\u0431\u043e\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u0432 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438) \u0432 \u043f\u043e\u043b\u0435 \u0432\u0432\u043e\u0434\u0430 \u0442\u0435\u043a\u0441\u0442\u0430, \u0430 \u0437\u0430\u0442\u0435\u043c \u043d\u0430\u0436\u0430\u0442\u044c <code>Enter</code></p> <p></p> <p>\u0414\u043b\u044f \u0444\u0438\u043b\u044c\u0442\u0440\u0430 \u043f\u043e \u0433\u0435\u043e \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0436\u0430\u0442\u044c \u043d\u0430 \u043a\u043d\u043e\u043f\u043a\u0443 <code>\u0413\u0435\u043e</code>, \u0432\u0432\u0435\u0441\u0442\u0438 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0441\u0442\u0440\u0430\u043d\u044b, \u043f\u043e \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0445\u043e\u0442\u0438\u043c \u0444\u0438\u043b\u044c\u0442\u0440\u043e\u0432\u0430\u0442\u044c, \u0430 \u0437\u0430\u0442\u0435\u043c \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u044d\u0442\u0443 \u0441\u0442\u0440\u0430\u043d\u0443</p> <p></p>"},{"location":"aio/campaigns/campaign-desc/#_3","title":"\u041a\u0430\u043a \u0437\u0430\u0439\u0442\u0438 \u0432 \u0441\u0430\u043c\u0443 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e","text":"<p>\u0414\u043b\u044f \u043f\u0435\u0440\u0435\u0445\u043e\u0434\u0430 \u0432 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0432 \u0441\u043f\u0438\u0441\u043a\u0435 \u0432\u0441\u0435\u0445 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0439 \u043d\u0430\u0436\u0430\u0442\u044c \u043d\u0430 \u043d\u0435\u0451 <code>\u041f\u0440\u0430\u0432\u043e\u0439 \u043a\u043d\u043e\u043f\u043a\u043e\u0439 \u043c\u044b\u0448\u0438</code> \u0438 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043f\u0443\u043d\u043a\u0442 <code>\u0420\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e</code></p> <p></p>"},{"location":"aio/campaigns/campaign-desc/#_4","title":"\u041a\u0430\u043a \u0443\u0441\u0442\u0440\u043e\u0435\u043d\u043e \u043e\u043a\u043d\u043e \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438","text":"<p>\u0412 \u043b\u0435\u0432\u043e\u0439 \u043f\u0430\u043d\u0435\u043b\u0438 \u0443\u043a\u0430\u0437\u0430\u043d\u044b \u0432\u0441\u0435 \u0434\u0435\u0442\u0430\u043b\u0438 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u043f\u043e \u0442\u0438\u043f\u0443 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u044f, \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f, \u0441\u0442\u0440\u0430\u043d\u044b, \u0434\u043b\u044f \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u0435\u0442\u0430\u043f, \u0432\u0441\u0435 \u043c\u0435\u0442\u043a\u0438 \u0438 \u0442.\u0434.</p> <p></p> <ol> <li><code>Name</code> - \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438. \u0415\u0433\u043e \u043c\u043e\u0436\u043d\u043e \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c, \u0434\u043e\u0431\u0430\u0432\u043b\u044f\u044f \u043d\u0443\u0436\u043d\u0443\u044e \u0432\u0430\u043c \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e.</li> <li><code>Color</code> - \u0446\u0432\u0435\u0442, \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u0431\u0443\u0434\u0435\u0442 \u0432\u044b\u0434\u0435\u043b\u0435\u043d\u043e \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0432 \u0441\u043f\u0438\u0441\u043a\u0435 \u0432\u0441\u0435\u0445 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0439. \u041c\u043e\u0436\u043d\u043e \u043c\u0435\u043d\u044f\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 \u043a\u0440\u0430\u0441\u043d\u044b\u0439, \u043a\u043e\u0433\u0434\u0430 \u0434\u043e\u043c\u0435\u043d \u043e\u0442\u0432\u0430\u043b\u0438\u043b\u0441\u044f \u0438 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e \u043c\u043e\u0436\u043d\u043e \u0443\u0434\u0430\u043b\u044f\u0442\u044c.</li> <li><code>Countries</code> - \u0441\u0442\u0440\u0430\u043d\u0430, \u043d\u0430 \u043a\u043e\u0442\u043e\u0440\u0443\u044e \u0431\u0443\u0434\u0435\u0442 \u0438\u0434\u0442\u0438 \u0442\u0440\u0430\u0444. \u0412\u044b\u0431\u043e\u0440 \u0441\u0442\u0440\u0430\u043d\u044b \u0432 \u044d\u0442\u043e\u043c \u043f\u043e\u043b\u0435 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u0444\u0438\u043b\u044c\u0442\u0440\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u043f\u043e <code>\u0433\u0435\u043e</code>.</li> <li><code>Tags</code> - \u0442\u0435\u0433\u0438 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u044e\u0442 \u0444\u0438\u043b\u044c\u0442\u0440\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u043f\u043e \u043d\u0443\u0436\u043d\u044b\u043c \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c. \u041a\u043e\u0433\u0434\u0430 \u043e\u0442\u0434\u0435\u043b \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u043e\u0442\u0434\u0430\u0451\u0442 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044e, \u0442\u043e \u0443 \u043d\u0435\u0451 \u0431\u0443\u0434\u0435\u0442 \u043b\u0438\u0448\u044c 1 \u0442\u0435\u0433 - \u0442\u0435\u0433 \u043a\u043e\u043c\u0430\u043d\u0434\u044b.</li> </ol> <p>\u0427\u0442\u043e \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0434\u0435\u043b\u0430\u0442\u044c, \u043a\u043e\u0433\u0434\u0430 \u0434\u043e\u043c\u0435\u043d \u0437\u0430\u0431\u0430\u043d\u0435\u043d</p> <p>\u0412 \u0442\u0430\u043a\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043f\u043e\u043c\u0435\u043d\u044f\u0442\u044c \u0446\u0432\u0435\u0442 \u0432\u043e \u0432\u0442\u043e\u0440\u043e\u043c \u043f\u0443\u043d\u043a\u0442\u0435 \u043d\u0430 \u043a\u0440\u0430\u0441\u043d\u044b\u0439 \u0438 \u043d\u0430\u0437\u043d\u0430\u0447\u0438\u0442\u044c \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u0442\u0435\u0433 <code>Banned</code>. \u041a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0441 \u0442\u0430\u043a\u0438\u043c\u0438 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c\u0438 \u0431\u0443\u0434\u0443\u0442 \u0443\u0434\u0430\u043b\u044f\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f \u043f\u043e\u0440\u044f\u0434\u043a\u0430 \u0432 \u0442\u0440\u0435\u043a\u0435\u0440\u0435.</p> <p></p> <ol> <li><code>Link domain</code> - \u0442\u0443\u0442 \u0443\u043a\u0430\u0437\u0430\u043d \u0434\u043e\u043c\u0435\u043d \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438. \u0415\u0433\u043e \u043c\u0435\u043d\u044f\u0442\u044c \u043d\u0435\u043b\u044c\u0437\u044f.</li> <li>\u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0437\u0430\u043a\u0440\u0435\u043f\u0438\u0442\u044c \u0434\u043e\u043c\u0435\u043d \u0437\u0430 \u044d\u0442\u043e\u0439 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0435\u0439 \u0438 \u043f\u0440\u0438 \u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u0438 \u0441\u0441\u044b\u043b\u043a\u0438 \u0447\u0435\u0440\u0435\u0437 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u043d\u043e\u0435 \u043c\u0435\u043d\u044e, \u0434\u043e\u043c\u0435\u043d \u0431\u0443\u0434\u0435\u0442 \u043d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d.</li> <li><code>Link source</code> - \u0442\u0443\u0442 \u0432\u044b\u0431\u0438\u0440\u0430\u0435\u0442\u0441\u044f \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a, \u043a\u0443\u0434\u0430 \u0431\u0443\u0434\u0435\u0442 \u0438\u0434\u0442\u0438 \u0442\u0440\u0430\u0444 \u0438 \u043a\u0430\u043a\u0438\u0435 \u043f\u043e\u043b\u044f \u0434\u043b\u044f \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u043e\u0442\u043e\u0431\u0440\u0430\u0437\u0438\u0442\u044c \u043d\u0438\u0436\u0435.</li> </ol>"},{"location":"aio/campaigns/campaign-desc/#google-fb","title":"\u041a\u0430\u043a \u0437\u0430\u043f\u043e\u043b\u043d\u044f\u0442\u044c \u043f\u043e\u043b\u044f \u0441 \u043c\u0435\u0442\u043a\u0430\u043c\u0438 (Google, FB)","text":"<ol> <li><code>FB Pixel</code> - \u043f\u0438\u043a\u0441\u0435\u043b\u044c, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0431\u0435\u0440\u0451\u0442\u0441\u044f \u0432 \u043a\u0430\u0431\u0438\u043d\u0435\u0442\u0435 FB \u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043a\u0430\u043a \u0434\u043b\u044f META, \u0442\u0430\u043a \u0438 \u0434\u043b\u044f API, \u0437\u0430\u043f\u043e\u043b\u043d\u044f\u0435\u0442\u0441\u044f \u0432 \u043b\u044e\u0431\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435</li> <li><code>FB CAPI Token</code> - \u044d\u0442\u043e \u0442\u043e\u043a\u0435\u043d, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0431\u0435\u0440\u0451\u0442\u0441\u044f \u0432 API \u043f\u0438\u043a\u0441\u0435\u043b\u044f \u0438 \u0437\u0430\u043f\u043e\u043b\u043d\u044f\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0432 \u0442\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435, \u0435\u0441\u043b\u0438 \u0437\u0430\u043b\u0438\u0432 \u0438\u0434\u0451\u0442 \u043d\u0430 API </li> </ol> <ol> <li><code>Creo ID</code> - \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043a\u0440\u0435\u043e</li> <li><code>Google Account ID</code> - \u044d\u0442\u043e ID \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u0430 google</li> <li><code>GTAG Conversion ID</code> - \u043f\u0435\u0440\u0432\u0430\u044f \u0447\u0430\u0441\u0442\u044c \u043f\u0438\u043a\u0441\u0435\u043b\u044f google, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0441\u044f \u043d\u0430 AW-...... \u0438 \u0432\u0441\u0451 \u0434\u043e \u0437\u043d\u0430\u043a\u0430 <code>/</code></li> <li><code>GTAG Conversion Label</code> - \u0432\u0442\u043e\u0440\u0430\u044f \u0447\u0430\u0441\u0442\u044c \u043f\u0438\u043a\u0441\u0435\u043b\u044f, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u043f\u043e\u0441\u043b\u0435 \u0437\u043d\u0430\u043a\u0430 <code>/</code></li> <li><code>GTAG ID</code> - \u0432\u0441\u0442\u0430\u0432\u043b\u044f\u0442\u044c \u0442\u043e\u0442 \u0436\u0435 <code>GTAG Conversion ID</code></li> <li><code>Target ID</code> - \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0442\u0430\u0440\u0433\u0435\u0442\u0430</li> </ol> <p>\u0412 \u043f\u0440\u0430\u0432\u043e\u0439 \u043f\u0430\u043d\u0435\u043b\u0438 \u0443\u043a\u0430\u0437\u0430\u043d <code>Flow</code> \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0441 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430\u043c\u0438 \u043a\u043b\u043e\u0430\u043a\u0438, \u0432\u0430\u0439\u0442\u0430 \u0438 \u043e\u0444\u0444\u0435\u0440\u0430</p> <p></p> <ol> <li><code>Traffic flow</code> - <code>Flow</code> \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438, \u043e\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0437\u0430 \u0442\u043e, \u043a\u0430\u043a \u0431\u0443\u0434\u0435\u0442 \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0430 \u043a\u043b\u043e\u0430\u043a\u0430 \u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0432\u0430\u0439\u0442\u0430/\u043e\u0444\u0444\u0435\u0440\u0430. \u042d\u0442\u043e \u043f\u043e\u043b\u0435 \u043c\u0435\u043d\u044f\u0442\u044c \u043d\u0435\u043b\u044c\u0437\u044f!</li> <li><code>Mode</code> - \u044d\u0442\u043e \u0442\u0438\u043f \u043a\u043b\u043e\u0430\u043a\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0441\u0435\u0439\u0447\u0430\u0441 \u0432\u044b\u0441\u0442\u0430\u0432\u043b\u0435\u043d<ol> <li><code>Filter</code> - \u044d\u0442\u043e \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c \u043a\u043b\u043e\u0430\u043a\u0438 \u0434\u043b\u044f \u0437\u0430\u043b\u0438\u0432\u0430. \u0426\u0435\u043b\u0435\u0432\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f \u0438\u0434\u0451\u0442 \u043d\u0430 <code>Black</code>, \u043d\u0435\u0446\u0435\u043b\u0435\u0432\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f \u0438\u0434\u0451\u0442 \u043d\u0430 <code>White</code>.</li> <li><code>Money</code> - \u043a\u043b\u043e\u0430\u043a\u0430 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 <code>Black</code>, \u0432\u0435\u0441\u044c \u0442\u0440\u0430\u0444 \u0438\u0434\u0451\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 \u043d\u0435\u0433\u043e.</li> <li><code>White</code> - \u043a\u043b\u043e\u0430\u043a\u0430 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 <code>White</code>, \u0432\u0435\u0441\u044c \u0442\u0440\u0430\u0444 \u0438\u0434\u0451\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 \u043d\u0435\u0433\u043e.</li> </ol> </li> <li><code>Allowed Countries</code> - \u0441\u0442\u0440\u0430\u043d\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0435\u0442 \u043a\u043b\u043e\u0430\u043a\u0430 \u043d\u0430 <code>Black</code>.</li> <li><code>Allowed Devices</code> - \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0435\u0442 \u043a\u043b\u043e\u0430\u043a\u0430 \u043d\u0430 <code>Black</code>.</li> </ol> <p></p> <ol> <li><code>White</code> - \u0442\u0443\u0442 \u0443\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043a\u0430\u043a\u043e\u0439 \u043b\u0435\u043d\u0434 \u0431\u044b\u043b \u0432\u044b\u0431\u0440\u0430\u043d \u0434\u043b\u044f \u043d\u0435\u0446\u0435\u043b\u0435\u0432\u043e\u0439 \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u0438</li> <li><code>Black</code> - \u0442\u0443\u0442 \u0443\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043a\u0430\u043a\u043e\u0439 \u043e\u0444\u0444\u0435\u0440 \u0431\u044b\u043b \u0432\u044b\u0431\u0440\u0430\u043d \u0434\u043b\u044f \u0446\u0435\u043b\u0435\u0432\u043e\u0439 \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u0438</li> </ol> <p>\u0412\u0430\u0436\u043d\u043e!</p> <p>\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 <code>Flow</code> \u0432 \u043f\u0440\u0430\u0432\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u043e\u043a\u043d\u0430 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0442\u0440\u043e\u0433\u0430\u0442\u044c \u043d\u0435\u043b\u044c\u0437\u044f.</p>"},{"location":"aio/campaigns/how-to-add-white/","title":"How to add white","text":""},{"location":"aio/campaigns/how-to-generate-link/","title":"\u041a\u0430\u043a \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443 \u0434\u043b\u044f \u0437\u0430\u043b\u0438\u0432\u0430","text":""},{"location":"aio/campaigns/how-to-generate-link/#_1","title":"\u041a\u0430\u043a \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443 \u0434\u043b\u044f \u0437\u0430\u043b\u0438\u0432\u0430","text":"<p>\u0412\u0430\u0436\u043d\u043e!</p> <p>\u0421\u0441\u044b\u043b\u043a\u0443 \u043d\u0443\u0436\u043d\u043e \u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u043e\u0441\u043b\u0435 \u0442\u043e\u0433\u043e, \u043a\u0430\u043a \u0432\u0441\u0435 \u043f\u043e\u043b\u044f \u0432 \u0441\u0430\u043c\u043e\u0439 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0431\u044b\u043b\u0438 \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u044b. \u0422\u043e \u0435\u0441\u0442\u044c, \u043f\u043e\u043b\u044f <code>FB Pixel</code>, <code>FB CAPI Token</code> \u0438\u043b\u0438 \u0436\u0435 <code>Google Account ID</code>, <code>Google Conversion ID</code>, <code>Google Conversion Label</code> \u0438 \u0442.\u0434.  \u0415\u0441\u043b\u0438 \u043d\u0435 \u0437\u0430\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043f\u043e\u043b\u044f, \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443, \u0430 \u043f\u043e\u0442\u043e\u043c \u0437\u0430\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043f\u043e\u043b\u044f, \u0442\u043e \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043f\u0435\u0440\u0435\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443, \u0432 \u043f\u0435\u0440\u0432\u043e\u043c \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u0435 \u043d\u0435 \u0431\u0443\u0434\u0443\u0442 \u043f\u043e\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u044b \u0434\u0430\u043d\u043d\u044b\u0435 \u0438\u0437 \u043f\u043e\u043b\u0435\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0431\u044b\u043b\u0438 \u0437\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u044b.</p>"},{"location":"aio/campaigns/how-to-generate-link/#_2","title":"\u041a\u0430\u043a \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443","text":"<p>\u0427\u0442\u043e\u0431\u044b \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0436\u0430\u0442\u044c \u043a\u043d\u043e\u043f\u043a\u0443 <code>\u0421\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0443</code></p> <p></p>"},{"location":"aio/campaigns/how-to-generate-link/#_3","title":"\u041a\u0430\u043a \u0441\u043a\u043e\u043f\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0433\u043e\u0442\u043e\u0432\u0443\u044e \u0441\u0441\u044b\u043b\u043a\u0443","text":"<p>\u041e\u0442\u043a\u0440\u043e\u0435\u0442\u0441\u044f \u043c\u043e\u0434\u0430\u043b\u044c\u043d\u043e\u0435 \u043e\u043a\u043d\u043e, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u043c \u043c\u043e\u0436\u043d\u043e \u0431\u0443\u0434\u0435\u0442 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0443\u044e \u0441\u0441\u044b\u043b\u043a\u0443 \u0441 \u043f\u043e\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043d\u044b\u043c\u0438 \u0432 \u043d\u0435\u0451 \u043c\u0435\u0442\u043a\u0430\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0431\u044b\u043b\u0438 \u0443\u043a\u0430\u0437\u0430\u043d\u044b \u0432 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438. </p> <p>\u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043d\u0430\u0436\u0430\u0442\u044c \u043d\u0430 \u0438\u043a\u043e\u043d\u043a\u0443 \u043a\u043e\u043f\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0441\u0441\u044b\u043b\u043a\u0438, \u043f\u043e\u0441\u043b\u0435 \u0447\u0435\u0433\u043e \u043e\u043d\u0430 \u0441\u043a\u043e\u043f\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u0432 \u0431\u0443\u0444\u0435\u0440 \u043e\u0431\u043c\u0435\u043d\u0430 \u0438 \u0441 \u043d\u0435\u0439 \u043c\u043e\u0436\u043d\u043e \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u0442\u044c \u0432\u0441\u0435 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u044b\u0435 \u043c\u0430\u043d\u0438\u043f\u0443\u043b\u044f\u0446\u0438\u0438.</p> <p></p> <p>\u0410\u043a\u043a\u0443\u0440\u0430\u0442\u043d\u043e</p> <p>\u0421\u0442\u043e\u0438\u0442 \u0430\u043a\u043a\u0443\u0440\u0430\u0442\u043d\u043e \u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u0441\u044b\u043b\u043a\u0438, \u0442\u0430\u043a \u043a\u0430\u043a \u0432\u0441\u0435 \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u0441\u0441\u044b\u043b\u043a\u0438 \"\u0440\u0430\u0431\u043e\u0447\u0438\u0435\" \u0438 \u0435\u0441\u043b\u0438 \u0431\u044b\u043b\u0430 \u0434\u043e\u043f\u0443\u0449\u0435\u043d\u0430 \u043e\u0448\u0438\u0431\u043a\u0430 \u0432 \u043f\u0435\u0440\u0432\u043e\u0439 \u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u0438, \u0441\u043a\u043e\u043f\u0438\u0440\u043e\u0432\u0430\u043d\u0430, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0430, \u043f\u043e\u0441\u043b\u0435 \u0447\u0435\u0433\u043e \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u043d\u0430 \u043d\u043e\u0432\u0430\u044f, \u0442\u043e \u043d\u0443\u0436\u043d\u043e \u0441\u043a\u043e\u043f\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u044d\u0442\u0443 \u043d\u043e\u0432\u0443\u044e \u0441\u0441\u044b\u043b\u043a\u0443 \u0438 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0451, \u0442\u0430\u043a \u043a\u0430\u043a \u043f\u0440\u0435\u0434\u044b\u0434\u0443\u0449\u0430\u044f \u0432\u0441\u0451 \u0435\u0449\u0451 \u0440\u0430\u0431\u043e\u0447\u0430\u044f \u0438 \u044d\u0442\u043e \u043c\u043e\u0436\u0435\u0442 \u0432\u0432\u0435\u0441\u0442\u0438 \u0432 \u0437\u0430\u0431\u043b\u0443\u0436\u0434\u0435\u043d\u0438\u0435.</p>"},{"location":"aio/campaigns/new-campaign/","title":"\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438","text":""},{"location":"aio/campaigns/new-campaign/#_1","title":"\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438","text":"<p>\u0423\u0442\u043e\u0447\u043d\u0435\u043d\u0438\u0435</p> <p>\u0412 AIO \u043f\u043e\u0447\u0442\u0438 \u043d\u0435\u0442 \u0440\u0430\u0437\u043d\u0438\u0446\u044b \u0432 \u0442\u043e\u043c, \u043f\u043e\u0434 \u043a\u0430\u043a\u043e\u0439 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a \u0434\u0435\u043b\u0430\u0435\u0442\u0441\u044f \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u044f. \u041e\u0444\u0444\u0435\u0440 \u0437\u0430\u0432\u0435\u0434\u0451\u043d \u0432 \u043e\u0434\u043d\u043e\u043c \u044d\u043a\u0437\u0435\u043c\u043f\u043b\u044f\u0440\u0435 \u0438 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u043e\u0434 \u043e\u0431\u0430 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430, \u0447\u0442\u043e <code>Google</code>, \u0447\u0442\u043e \u043f\u043e\u0434 <code>Facebook</code>. \u0415\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u043e\u0442\u043b\u0438\u0447\u0438\u0435 - \u044d\u0442\u043e \u0432\u044b\u0431\u043e\u0440 <code>\u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430</code> \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0441\u0430\u043c\u043e\u0439 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438. \u042d\u0442\u043e\u0442 \u043c\u043e\u043c\u0435\u043d\u0442 \u0431\u0443\u0434\u0435\u0442 \u0440\u0430\u0441\u0441\u043c\u043e\u0442\u0440\u0435\u043d \u0447\u0443\u0442\u044c \u043f\u043e\u0437\u0436\u0435.</p>"},{"location":"aio/campaigns/new-campaign/#_2","title":"\u0417\u0430\u043f\u0440\u043e\u0441 \u043d\u0430 \u0437\u0430\u043a\u0443\u043f\u043a\u0443 \u0438 \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0434\u043e\u043c\u0435\u043d\u043e\u0432","text":"<p>\u041f\u0435\u0440\u0432\u044b\u043c \u0434\u0435\u043b\u043e\u043c \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043f\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0437\u0430\u0434\u0430\u0447\u0443 \u043d\u0430 \u0437\u0430\u043a\u0443\u043f\u043a\u0443 \u0438 \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0434\u043e\u043c\u0435\u043d\u043e\u0432 \u0432 <code>AIO</code>. \u041a\u043e\u043c\u0430\u043d\u0434\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0434\u043e\u0431\u0430\u0432\u0438\u0442 \u0434\u043e\u043c\u0435\u043d\u044b \u0432 \u0442\u0440\u0435\u043a\u0435\u0440 \u0438 \u043e\u043d\u0438 \u0431\u0443\u0434\u0443\u0442 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0433\u043e\u0442\u043e\u0432\u044b \u043a \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044e.</p> <p></p> <p>\u041f\u0440\u0438\u043c\u0435\u0440 \u0437\u0430\u0434\u0430\u0447\u0438 \u043d\u0430 \u0437\u0430\u043a\u0443\u043f\u043a\u0443 \u0438 \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0434\u043e\u043c\u0435\u043d\u043e\u0432</p> <pre><code>\u041f\u0440\u043e\u0448\u0443 \u0437\u0430\u043a\u0443\u043f\u0438\u0442\u044c \u0438 \u0437\u0430\u0432\u0435\u0441\u0442\u0438 \u0434\u043e\u043c\u0435\u043d\u044b \u0432 AIO.\n\n\u0421\u043f\u0438\u0441\u043e\u043a \u0434\u043e\u043c\u0435\u043d\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0437\u0430\u0432\u0435\u0441\u0442\u0438:\ndomain1.com\ndomain1.com\ndomain1.com\ndomain1.com\ndomain1.com\n</code></pre> <p></p>"},{"location":"aio/campaigns/new-campaign/#aio","title":"\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u043a\u0430\u043c\u043f\u0430\u043d\u0438\u0438 \u0432 AIO","text":"<p>\u041a\u043e\u0433\u0434\u0430 \u0434\u043e\u043c\u0435\u043d\u044b \u0437\u0430\u043a\u0443\u043f\u043b\u0435\u043d\u044b, \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u044b \u0432 <code>AIO</code> \u0438 \u0432\u0430\u0441 \u043e\u043f\u043e\u0432\u0435\u0441\u0442\u0438\u043b\u0438 \u043e \u0442\u043e\u043c, \u0447\u0442\u043e \u043e\u043d\u0438 \u0433\u043e\u0442\u043e\u0432\u044b \u043a \u0440\u0430\u0431\u043e\u0442\u0435, \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043f\u0435\u0440\u0435\u0439\u0442\u0438 \u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443  </p>"},{"location":"aio/regulations/regulations/","title":"\u0420\u0435\u0433\u043b\u0430\u043c\u0435\u043d\u0442\u044b \u0434\u043b\u044f \u0437\u0430\u0434\u0430\u0447","text":""}]}